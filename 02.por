programa
{
	funcao inicio()
	{
		inteiro remessa1, remessa2, estoqueTotal

		escreva("Digite a quantidade da primeira remessa: ")
		leia(remessa1)

		escreva("Digite a quantidade da segunda remessa: ")
		leia(remessa2)

		estoqueTotal = remessa1 + remessa2

		escreva("Estoque total disponível: ", estoqueTotal)
	}
}